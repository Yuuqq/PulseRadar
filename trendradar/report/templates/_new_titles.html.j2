{#- 本次新增热点 -#}
{#- Context vars:
      total_new_count : int
      sources         : list[dict] with keys: source_name, items
      items           : list[dict] with keys: number, rank_class, rank_text, escaped_title, link_url
-#}

                <div class="new-section">
                    <div class="new-section-title"><span data-i18n-en="What's New" data-i18n-zh="本次新增热点">What's New</span> (<span data-i18n-en="total" data-i18n-zh="共">total</span> {{ total_new_count }}<span data-i18n-en="" data-i18n-zh=" 条"></span>)</div>
{%- for src in sources %}
                    <div class="new-source-group">
                        <div class="new-source-title">{{ src.source_name }} · {{ src['items']|length }}<span data-i18n-en="" data-i18n-zh="条"></span></div>
{%- for it in src['items'] %}
                        <div class="new-item">
                            <div class="new-item-number">{{ it.number }}</div>
                            <div class="new-item-rank {{ it.rank_class }}">{{ it.rank_text }}</div>
                            <div class="new-item-content">
                                <div class="new-item-title">{% if it.link_url %}<a href="{{ it.link_url }}" target="_blank" class="news-link">{{ it.title }}</a>{% else %}{{ it.title }}{% endif %}
                                </div>
                            </div>
                        </div>
{%- endfor %}
                    </div>
{%- endfor %}
                </div>
